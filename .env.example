# ============================================================
# IMPORTANTE: este fichero va en la RAÍZ del monorepo.
# El backend lo lee desde el cwd del proceso (la raíz),
# NO desde packages/backend/.env.
# Copia este fichero como .env en la raíz y rellena los valores.
# NUNCA subas .env a git.
# ============================================================

NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:pass@localhost:5433/invoicescan
REDIS_URL=redis://localhost:6379
JWT_SECRET=                    # min 32 chars
JWT_REFRESH_SECRET=            # min 32 chars, diferente al anterior
FRONTEND_URL=http://localhost:3001
MAX_UPLOAD_SIZE_MB=10

# ── Email — Resend (opcional) ──────────────────────────────────────────────
# Sin estas variables los emails son no-op (la app arranca igualmente).
# Obtén tu API key en https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=             # ej: "InvoiceScan <noreply@tudominio.com>"

# ── Google AI Studio — extracción LLM (opcional) ──────────────────────────
# Sin estas variables el GenericAdapter LLM está desactivado.
# Obtén tu API key en https://aistudio.google.com/app/apikey
AISTUDIO_API_KEY=
AISTUDIO_MODEL=                # ej: gemini-1.5-flash

# ── OpenTelemetry (opcional) ───────────────────────────────────────────────
# Sin esto la app arranca en modo no-op (no traces, no metrics enviadas).
# Para usar con SigNoz local: docker compose --profile observability up
OTEL_EXPORTER_OTLP_ENDPOINT=  # ej: http://localhost:4318
OTEL_SERVICE_NAME=invoice-flow-backend

# ── Docker / full profile ─────────────────────────────────────────────────
# Usado por: docker compose --profile full up
# Construir primero: docker compose --profile full build
#
# URL pública de la API que el frontend bake en el bundle
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
