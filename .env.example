# ============================================================
# IMPORTANTE: este fichero va en la RAÍZ del monorepo.
# El backend lo lee desde el cwd del proceso (la raíz),
# NO desde packages/backend/.env.
# Copia este fichero como .env en la raíz y rellena los valores.
# NUNCA subas .env a git.
# ============================================================

NODE_ENV=
PORT=
DATABASE_URL=
REDIS_URL=
JWT_SECRET=                    # min 32 chars
JWT_REFRESH_SECRET=            # min 32 chars, diferente al anterior
FRONTEND_URL=                  # ej: http://localhost:3001
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAX_UPLOAD_SIZE_MB=
GOOGLE_VISION_API_KEY=         # opcional
AISTUDIO_API_KEY=              # requerido para extracción LLM (Google AI Studio)
AISTUDIO_MODEL=                # opcional, default: gemini-1.5-flash
RESEND_API_KEY=                # Get from https://resend.com/api-keys
RESEND_FROM_EMAIL=             # ej: "InvoiceScan <onboarding@resend.dev>"
